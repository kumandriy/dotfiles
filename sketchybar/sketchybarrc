#!/usr/bin/env bash

# ~/.config/sketchybar/sketchybarrc
# Rebuilt from scratch. Item/plugin/event-driven model:
#   items/*.sh   -> declare bar items (left/right, styling, click actions)
#   plugins/*.sh -> shell scripts invoked by sketchybar events to update items
#
# Docs: https://felixkratz.github.io/SketchyBar/

source "$HOME/.config/sketchybar/colors.sh"
source "$HOME/.config/sketchybar/icons.sh"

export ITEM_DIR="$HOME/.config/sketchybar/items"
export PLUGIN_DIR="$HOME/.config/sketchybar/plugins"
export FONT="SF Pro"

PADDINGS=6

##### Bar appearance: docked flush at the top of the screen #####
sketchybar --bar \
  position=top \
  height=34 \
  color=$BAR_COLOR \
  border_width=0 \
  corner_radius=0 \
  y_offset=0 \
  margin=0 \
  padding_left=10 \
  padding_right=10 \
  sticky=on \
  blur_radius=25 \
  shadow=off \
  \
  --default \
  updates=when_shown \
  icon.font="$ICON_FONT:Regular:15.0" \
  icon.color=$ICON_COLOR \
  icon.padding_left=$PADDINGS \
  icon.padding_right=$PADDINGS \
  label.font="$FONT:Semibold:13.0" \
  label.color=$LABEL_COLOR \
  label.padding_left=$PADDINGS \
  label.padding_right=$PADDINGS \
  background.padding_left=4 \
  background.padding_right=4

##### Left: workspaces + live app list for the active workspace #####
source "$ITEM_DIR/aerospace.sh"

##### Right: system status, right-to-left visual order = cpu, wifi, volume, battery, clock #####
source "$ITEM_DIR/clock.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"
# source "$ITEM_DIR/wifi.sh"
source "$ITEM_DIR/cpu.sh"

##### Finalize #####
sketchybar --update

echo "sketchybar configuration loaded"
